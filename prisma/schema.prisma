generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id           String        @id @default(cuid())
  name         String
  customFields Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clips        Int?
  earned       Decimal?
  isCompleted  Boolean       @default(false)
  niche        String?
  platform     String?
  rpm          String?
  rules        String?
  sound        String?
  views        String?
  lastExport       String?
  discordThreadUrl String?
  identityId       String?
  identity         Identity?     @relation(fields: [identityId], references: [id])
  contexts         ContextItem[] @relation("CampaignToContextItem")
}

model ContextCategory {
  id          String        @id @default(cuid())
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  description String?
  identityId  String?
  identity    Identity?     @relation(fields: [identityId], references: [id])
  items       ContextItem[]
}

model ContextItem {
  id         String          @id @default(cuid())
  name       String
  text       String
  categoryId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   ContextCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  campaigns  Campaign[]      @relation("CampaignToContextItem")

  @@index([categoryId])
}

model StoredContent {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyTimer {
  id            String    @id @default(cuid())
  date          String    @unique
  seconds       Int       @default(0)
  isRunning     Boolean   @default(false)
  lastStartedAt DateTime?
  updatedAt     DateTime  @updatedAt
}

model Identity {
  id                String            @id @default(cuid())
  name              String            @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaigns         Campaign[]
  contextCategories ContextCategory[]
}
